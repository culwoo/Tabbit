{
  "expo": {
    "name": "Tabbit",
    "slug": "tabbit",
    "version": "1.0.0",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "tabbit",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.tabbit.app",
      "buildNumber": "1"
    },
    "android": {
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#F6F3FA",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "softwareKeyboardLayoutMode": "resize",
      "googleServicesFile": "./google-services.json",
      "predictiveBackGestureEnabled": false,
      "package": "com.tabbit.app",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_VISUAL_USER_SELECTED"
      ],
      "blockedPermissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.READ_MEDIA_AUDIO",
        "android.permission.SYSTEM_ALERT_WINDOW"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "Tabbit에서 인증 사진을 바로 촬영하려면 카메라 권한이 필요합니다."
        }
      ],
      [
        "expo-image-picker",
        {
          "cameraPermission": "Tabbit에서 인증 사진을 촬영하려면 카메라 권한이 필요합니다.",
          "photosPermission": "Tabbit에서 기존 인증 사진을 가져오려면 사진 보관함 권한이 필요합니다."
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "Tabbit에서 저장한 스토리 이미지를 다시 선택하려면 사진 접근 권한이 필요합니다.",
          "savePhotosPermission": "Tabbit 스토리 이미지를 기기에 저장하려면 사진 보관함 접근 권한이 필요합니다.",
          "isAccessMediaLocationEnabled": false
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#9B7FD4",
          "defaultChannel": "tabbit-default"
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#F6F3FA",
          "dark": {
            "backgroundColor": "#F6F3FA"
          }
        }
      ],
      "expo-web-browser"
    ],
    "experiments": {
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "44d3a8a8-dcac-48ea-a934-cac68b6681e8"
      }
    }
  }
}
