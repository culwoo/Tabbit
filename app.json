{
  "expo": {
    "name": "Tabbit",
    "slug": "tabbit",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "tabbit",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.tabbit.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.tabbit.app"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "cameraPermission": "Tabbit에서 인증 사진을 촬영하려면 카메라 권한이 필요합니다.",
          "photosPermission": "Tabbit에서 기존 인증 사진을 가져오려면 사진 라이브러리 권한이 필요합니다."
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "Tabbit에서 저장한 스토리 이미지를 다시 선택하려면 사진 접근 권한이 필요합니다.",
          "savePhotosPermission": "Tabbit 스토리 이미지를 기기 앨범에 저장하려면 사진 보관함 접근 권한이 필요합니다.",
          "isAccessMediaLocationEnabled": false
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-web-browser"
    ],
    "experiments": {
      "reactCompiler": true
    }
  }
}
